# Copy to .env.development / .env.local and adjust.
# Dev: full Laravel origin. Prod: leave empty for same-origin `/` routes.

VITE_API_BASE_URL=http://localhost

# Intercom messenger (`@intercom/messenger-js-sdk`). Required for the support button to open chat.
VITE_INTERCOM_APP_ID=jyk27uux

# Optional; must match Laravel PLAYER_EMAIL_DOMAIN so old cached auth still skips synthetic emails in Intercom.
# VITE_PLAYER_EMAIL_DOMAIN=players.local
