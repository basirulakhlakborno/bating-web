APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Comma-separated browser origins (Vite dev + production SPA). Include https://gg.eimtbd.com when live.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://[::1]:5173,https://gg.eimtbd.com,http://gg.eimtbd.com
JWT_SECRET=
JWT_TTL_MINUTES=120

# Referral: BDT cumulative deposit threshold for one-time ৳500+৳500 milestone (referrer + referee).
REFERRAL_DEPOSIT_THRESHOLD=2000
REFERRAL_BONUS_REFERRER=500
REFERRAL_BONUS_REFEREE=500

# Deposits: JWT route POST /api/deposit — off in production (players must not self-credit).
DEPOSIT_JWT_ENABLED=false
DEPOSIT_WEBHOOK_ENABLED=true
# Required for POST /api/webhooks/deposit — HMAC-SHA256(raw_body, secret) as hex in X-Webhook-Signature
DEPOSIT_WEBHOOK_SECRET=
DEPOSIT_MAX_AMOUNT=10000000
DEPOSIT_THROTTLE_PER_MINUTE=30

# HTTP rate limits (see config/rate_limiting.php). JWT player APIs use per-user buckets when Bearer is valid.
# RATE_LIMIT_LOGIN_PER_MINUTE=12
# RATE_LIMIT_REGISTER_PER_MINUTE=8
# RATE_LIMIT_CAPTCHA_PER_MINUTE=45
# RATE_LIMIT_CSRF_PER_MINUTE=120
# RATE_LIMIT_API_READ_USER_MINUTE=300
# RATE_LIMIT_API_READ_IP_MINUTE=180
# RATE_LIMIT_API_WRITE_USER_MINUTE=45
# RATE_LIMIT_API_WRITE_IP_MINUTE=24
# RATE_LIMIT_WITHDRAW_USER_MINUTE=36
# RATE_LIMIT_WITHDRAW_IP_MINUTE=24
# RATE_LIMIT_SPA_HTML_PER_MINUTE=300
# RATE_LIMIT_ADMIN_PER_MINUTE=400
# RATE_LIMIT_DEPOSIT_WEBHOOK_PER_MINUTE=600

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=babu88
DB_USERNAME=root
DB_PASSWORD=

# Synthetic emails for username registration: {username}@{PLAYER_EMAIL_DOMAIN}
PLAYER_EMAIL_DOMAIN=players.local

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Babu88 Blade / download bar (optional)
# BABU88_DOWNLOAD_MESSAGE=
# BABU88_DOWNLOAD_BUTTON=
# BABU88_DOWNLOAD_ICON=/static/image/layout/download-app.png
# BABU88_DOWNLOAD_HREF=
